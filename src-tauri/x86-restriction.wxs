<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- This condition ensures the installer only runs on 32-bit Windows -->
    <Condition Message="This 32-bit installer is strictly for 32-bit systems. Please use the 64-bit installer for this computer.">
      <![CDATA[Installed OR NOT VersionNT64]]>
    </Condition>

    <!-- We define a dummy component group to force the linker to include this fragment -->
    <ComponentGroup Id="X86Restriction">
      <Component Id="X86RestrictionDummy" Guid="B7C8E9A0-D1C2-4B3A-8F9E-7D6C5B4A3A2F" Directory="INSTALLDIR">
        <Condition>0</Condition> <!-- This component will never actually install anything -->
        <CreateFolder />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
